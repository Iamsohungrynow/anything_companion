# ============================================================================
# Yorimi runtime environment (matches server/config.js on main)
# Copy this file to .env for local development:   cp .env.example .env
# .env is gitignored — NEVER commit real keys.
# On Vercel, set these in Project -> Settings -> Environment Variables (not a file).
# ============================================================================

# ----------------------------------------------------------------------------
# LLM providers — the chat "brain"
# The runtime tries providers in order and falls through on failure:
#   1) Doubao (Volcengine Ark)  -> needs VOLC_ARK_API_KEY
#   2) OpenAI                    -> needs OPENAI_API_KEY
#   3) deterministic mock        -> always works, no keys (demo / offline)
# Set at least ONE real provider for live AI. With neither, chat is mock-only.
# ----------------------------------------------------------------------------

# --- OpenAI (overseas / Singapore default) ---
# Required for live OpenAI. If empty AND Doubao is empty, the backend serves mock.
OPENAI_API_KEY=
# Chat model sent to the OpenAI Responses API. Must be a model your account can access.
OPENAI_MODEL=gpt-5.4-mini
# Model used only when a request needs live web search (search-capable model).
OPENAI_SEARCH_MODEL=gpt-5.5
# OpenAI request timeout (ms) before falling through to the next provider.
OPENAI_TIMEOUT_MS=12000

# --- Doubao via Volcengine Ark (China-first / optional) ---
# When set, Doubao becomes the PRIMARY chat engine (tried before OpenAI).
# When empty, the Doubao step is skipped instantly (throws before any network call).
# Get a key: Volcengine Ark (console.volcengine.com/ark — needs China real-name)
#            or BytePlus ModelArk (byteplus.com — international, works from Singapore).
# NOTE: the client currently targets the China Ark host. To use BytePlus, the base
# URL + model id must be changed in server/engines/doubao/client.js.
VOLC_ARK_API_KEY=
# Doubao chat model id. Must be enabled/开通 on your Ark account.
VOLC_CHAT_MODEL=doubao-1-5-pro-32k-250115
# Doubao request timeout (ms) before falling through to OpenAI/mock.
VOLC_CHAT_TIMEOUT_MS=20000

# ----------------------------------------------------------------------------
# STT — speech to text (POST /api/stt, used for push-to-talk voice input)
# Fallback order: chosen provider -> OpenAI Whisper -> browser SpeechRecognition.
# Browsers with local SpeechRecognition can do voice input with no keys at all.
# ----------------------------------------------------------------------------
# "volcano" = Volcengine ASR (needs the VOLC_APP_ID/ACCESS_TOKEN/SECRET_KEY below).
# "openai"  = skip Volcano, go straight to Whisper (set this if you have no Volcano ASR).
STT_PROVIDER=volcano
# OpenAI Whisper model used as the STT fallback (needs OPENAI_API_KEY).
STT_MODEL=whisper-1
# Volcengine ASR (一句话识别) credentials — only needed when STT_PROVIDER=volcano.
VOLC_APP_ID=
VOLC_ACCESS_TOKEN=
VOLC_SECRET_KEY=
VOLC_ASR_CLUSTER=volcengine_input_common

# ----------------------------------------------------------------------------
# TTS — text to speech (POST /api/tts, optional)
# Leave blank to use the browser's speechSynthesis. Chat never blocks on TTS.
# ----------------------------------------------------------------------------
FISH_AUDIO_API_KEY=
FISH_AUDIO_REFERENCE_ID=
FISH_AUDIO_TIMEOUT_MS=20000

# ----------------------------------------------------------------------------
# Local server
# ----------------------------------------------------------------------------
PORT=3017
HOST=127.0.0.1
# Force mock responses even when keys are set (rehearsal / offline judging).
USE_MOCK_AI=false

# ----------------------------------------------------------------------------
# Networking (browser CORS + Host header allowlist)
# Localhost is enough for local dev. Vercel *.vercel.app hosts are auto-allowed.
# For a custom domain, add it to both lists.
# ----------------------------------------------------------------------------
ALLOWED_ORIGINS=http://localhost:3017,http://127.0.0.1:3017
ALLOWED_HOSTS=127.0.0.1,localhost,::1

# ----------------------------------------------------------------------------
# Sessions (in-memory)
# ----------------------------------------------------------------------------
# Max in-memory sessions before the oldest are evicted.
MAX_SESSIONS=250
# Session TTL in ms. Default: 8 hours.
SESSION_TTL_MS=28800000
