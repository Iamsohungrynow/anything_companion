# Copy this file to .env for local development.
# Never commit real API keys.

# Required for live AI. If unset, the backend uses schema-compatible mock fallback.
OPENAI_API_KEY=

# Optional. Used by server/engines/openai/client.js when OPENAI_API_KEY is set.
# gpt-5.4-mini is a realistic default for demo latency/cost.
# Use gpt-5.5 if you want maximum quality and can tolerate higher cost.
OPENAI_MODEL=gpt-5.4-mini

# Optional. Used only when the request needs current/external web information.
# Responses API web_search works best with a search-capable frontier model.
OPENAI_SEARCH_MODEL=gpt-5.5

# Optional. Backend port for npm run dev / npm start.
# Use 3017 if you want the same local URL used in the demo screenshots.
PORT=3017

# Optional. Backend host. Keep 127.0.0.1 for local-only development.
HOST=127.0.0.1

# Optional. Comma-separated origins allowed to call the API from a browser.
# For Vercel custom domains, add https://your-domain.example.
ALLOWED_ORIGINS=http://localhost:3017,http://127.0.0.1:3017

# Optional. Comma-separated Host headers accepted by the backend.
# Localhost is enough for local dev. Vercel *.vercel.app hosts are allowed automatically on Vercel.
# For custom domains, add your-domain.example in Vercel dashboard.
ALLOWED_HOSTS=127.0.0.1,localhost,::1

# Optional. Force local mock responses even when OPENAI_API_KEY is set.
# Set to true for rehearsal or offline judging.
USE_MOCK_AI=false

# Optional. OpenAI request timeout in milliseconds before fallback is used.
# 12s is enough for structured output during demos without hanging the UI too long.
OPENAI_TIMEOUT_MS=12000

# Optional. Model used by POST /api/stt when browser speech recognition is unavailable.
# Browsers that support local SpeechRecognition can still do voice input without this path.
STT_MODEL=whisper-1

# Optional. Fish Audio TTS proxy used by POST /api/tts.
# Leave these blank unless you have real Fish Audio credentials.
# Chat mode still falls back to browser speechSynthesis when this is blank.
FISH_AUDIO_API_KEY=
FISH_AUDIO_REFERENCE_ID=
FISH_AUDIO_TIMEOUT_MS=20000

# Optional. Maximum in-memory sessions before oldest sessions are evicted.
MAX_SESSIONS=250

# Optional. Session TTL in milliseconds. Default: 8 hours.
SESSION_TTL_MS=28800000
