# Copy this file to .env for local development.
# Never commit real API keys.

# Optional. If unset, the backend automatically uses the local mock fallback.
OPENAI_API_KEY=

# Optional. Used by server/openai/client.js when OPENAI_API_KEY is set.
# gpt-5.4-mini is a realistic default for demo latency/cost.
# Use gpt-5.5 if you want maximum quality and can tolerate higher cost.
OPENAI_MODEL=gpt-5.4-mini

# Optional. Backend port for npm run dev / npm start.
PORT=3000

# Optional. Backend host. Keep 127.0.0.1 for local-only development.
HOST=127.0.0.1

# Optional. Comma-separated origins allowed to call the API from a browser.
ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Optional. Comma-separated Host headers accepted by the backend.
ALLOWED_HOSTS=127.0.0.1,localhost,::1

# Optional. Force local mock responses even when OPENAI_API_KEY is set.
# Set to true for rehearsal or offline judging.
USE_MOCK_AI=false

# Optional. OpenAI request timeout in milliseconds before fallback is used.
# 12s is enough for structured output during demos without hanging the UI too long.
OPENAI_TIMEOUT_MS=12000

# Optional. Fish Audio TTS proxy used by POST /api/tts.
FISH_AUDIO_API_KEY=your_fish_audio_key_here
FISH_AUDIO_REFERENCE_ID=your_fish_audio_reference_id_here
FISH_AUDIO_TIMEOUT_MS=20000

# Optional. Maximum in-memory sessions before oldest sessions are evicted.
MAX_SESSIONS=250

# Optional. Session TTL in milliseconds. Default: 8 hours.
SESSION_TTL_MS=28800000
