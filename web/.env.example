# Origin of the Yorimi runtime API that this app proxies /api/* to
# (chat, TTS, STT). See next.config.mjs rewrites.
#
# Local dev: leave unset -> defaults to http://127.0.0.1:3017 (server/index.js).
# Production (Vercel): set this to your deployed BACKEND project URL, e.g.
#   YORIMI_API_ORIGIN=https://yorimi.vercel.app
# Without it, /api/* calls (chat + voice) will fail in production.
YORIMI_API_ORIGIN=http://127.0.0.1:3017
