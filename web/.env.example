# The web app now hosts the Yorimi runtime itself (app/api/[...path]/route.ts),
# so it needs the provider keys directly. Locally, copy this to web/.env.
# On Vercel, set these as the project's Environment Variables (not a .env file).
#
# With no keys set, chat falls back to schema-compatible mock behavior, and
# TTS/STT return a clear "not configured" response.

# Chat (OpenAI path; Doubao streaming used when VOLC_ARK_API_KEY is set)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.4-mini
USE_MOCK_AI=false

# Voice output (Fish Audio TTS) - both required for /api/tts
FISH_AUDIO_API_KEY=
FISH_AUDIO_REFERENCE_ID=

# Voice input (STT). "volcano" uses VOLC_* creds; falls back to OpenAI Whisper.
STT_PROVIDER=volcano
STT_MODEL=whisper-1
VOLC_APP_ID=
VOLC_ACCESS_TOKEN=
VOLC_ASR_CLUSTER=volcengine_input_common

# Doubao / Volcengine Ark chat (optional; enables streaming chat)
VOLC_ARK_API_KEY=
VOLC_CHAT_MODEL=doubao-1-5-pro-32k-250115
